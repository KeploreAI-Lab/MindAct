{
  "name": "mindact",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run server.ts\" \"cd client && bun run dev\"",
    "server": "bun run server.ts",
    "build": "cd client && bun run build",
    "start": "bun run build && bun run server.ts",
    "calib:collect": "CALIB_SAMPLES=100 bun run scripts/calibration_collect.ts",
    "calib:fit": "bun run scripts/calibration_fit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@keploreai/physmind": "^2.1.891",
    "adm-zip": "^0.5.17",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "electron": "^40.8.5"
  }
}
