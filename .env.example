# Copy this file to .env and fill in your values
# cp .env.example .env

# MindAct AI provider selection
MINDACT_AI_PROVIDER=minimax

# --- Minimax: OpenAI-compatible API ---
# api.minimax.chat/v1 accepts Authorization: Bearer (this key works here)
# api.minimax.io/anthropic does NOT accept this key (401)
MINDACT_MINIMAX_API_STYLE=openai
MINDACT_MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINDACT_MINIMAX_API_KEY=your_minimax_api_key_here
# openai/ prefix forces CLI to route to OpenAI-compatible provider
MINDACT_MINIMAX_MODEL=openai/MiniMax-M2.7

# --- Generic OpenAI-compatible settings (if you use a proxy like LiteLLM) ---
# MINDACT_OPENAI_BASE_URL=http://127.0.0.1:4000/v1
# MINDACT_OPENAI_API_KEY=your_key_here
# MINDACT_OPENAI_MODEL=gpt-4o-mini

# --- Anthropic fallback ---
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

